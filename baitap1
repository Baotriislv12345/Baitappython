import tkinter as tk
import math

def tinh():
    try:
        S = float(entry.get())
        R = math.sqrt(S / (4 * math.pi))
        V = (4/3) * math.pi * R**3
        label.config(text=f"V = {V:.4f}")
    except:
        label.config(text="Lỗi nhập")

root = tk.Tk()
root.title("Bài 1")

tk.Label(root, text="Nhập S:").pack()
entry = tk.Entry(root)
entry.pack()

tk.Button(root, text="Tính", command=tinh).pack()
label = tk.Label(root)
label.pack()

root.mainloop()